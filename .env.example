# IMAP 설정 (New Outlook / 클래식 Outlook 공통)
# MFA 계정: https://account.microsoft.com/security → 고급 보안 → 앱 비밀번호 생성
IMAP_SERVER=outlook.office365.com
IMAP_PORT=993
IMAP_USERNAME=your-email@company.com
IMAP_PASSWORD=your-app-password

# Power Automate Teams bridge
TEAMS_BRIDGE_PREFIX=[TEAMS]

# Outlook 폴링 옵션
OUTLOOK_UNREAD_ONLY=true
OUTLOOK_LOOKBACK_HOURS=24

# 웹훅 / 대시보드 보안
# WEBHOOK_SECRET: Power Automate 요청 검증용 (선택)
WEBHOOK_SECRET=
# DASHBOARD_SECRET: 대시보드·리포트 HTTP Basic Auth 비밀번호 (설정 시 인증 활성화)
# 브라우저에서 /dashboard 접근 시 팝업 로그인창 표시, 비밀번호에 이 값을 입력
DASHBOARD_SECRET=

# Jira
JIRA_SERVER=https://yourorg.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=PROJ

# Ollama (실행: ollama serve && ollama pull llama3.2)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Agent behavior
POLL_INTERVAL_SECONDS=60
RULE_CONFIDENCE_THRESHOLD=0.8
STATE_DB_PATH=state.db

# 메일 수집 트리거 URL (대시보드 "지금 가져오기" 버튼용)
# Make.com에서 Custom webhook 모듈 생성 후 URL 복사해 붙여넣기
TRIGGER_URL=
